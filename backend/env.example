# Flask Configuration
FLASK_SECRET_KEY=dev-secret-key-change-in-production
FLASK_ENV=development
JWT_SECRET_KEY=jwt-secret-key-change-in-production

# Database Configuration
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=algo_trading

# Angel One API Configuration (Demo/Test Credentials)
# Note: These are placeholder values. Replace with actual Angel One credentials
API_KEY=your_api_key_here
CLIENT_ID=your_client_id_here
TOTP_SECRET=your_totp_secret_here
CLIENT_PIN=your_client_pin_here

# Telegram Configuration (Optional)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# Admin Credentials
DEFAULT_ADMIN_USER=admin
DEFAULT_ADMIN_PASSWORD=admin123

# Trading Configuration
DEFAULT_CANDLE_INTERVAL=1
PAPER_TRADING_MODE=true
MAX_VOLATILE_STOCKS=10

# Technical Indicators Configuration
RSI_PERIOD=14
MACD_FAST=12
MACD_SLOW=26
MACD_SIGNAL=9
SUPERTREND_PERIOD=10
SUPERTREND_MULTIPLIER=3.0
VWAP_PERIOD=20

# Risk Management
DEFAULT_RISK_REWARD_RATIO=1.5
TRAILING_STOP_PERCENTAGE=0.5
MAX_DAILY_LOSS=1000
MAX_POSITION_SIZE=10000 